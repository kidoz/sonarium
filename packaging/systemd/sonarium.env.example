# Sonarium environment for systemd units. Install as /etc/sonarium/sonarium.env
# (mode 0600, owned by root — it holds the token secret and DB credentials).

SONARIUM_MODE=production

# LAN address the services bind and advertise. Use SONARIUM_ALLOW_PUBLIC_BIND=1
# instead if you really want 0.0.0.0.
SONARIUM_DLNA_BIND_HOST=192.168.1.10
SONARIUM_SERVER_BIND_HOST=192.168.1.10

# openssl rand -hex 32
SONARIUM_MEDIA_TOKEN_SECRET=change-me

SONARIUM_PG_CONNINFO="host=127.0.0.1 port=5432 user=sonarium password=change-me dbname=sonarium"
# … or skip Postgres entirely with a single-file SQLite catalog:
#SONARIUM_SQLITE_PATH=/var/lib/sonarium/catalog.db

# Library root: containment boundary for served files, scan root for the worker.
SONARIUM_MEDIA_ROOT=/srv/music

# Where HLS playlists point clients for direct media: the sonarium-dlna
# HTTP endpoint (its default port is 8200).
SONARIUM_MEDIA_BASE_URL=http://192.168.1.10:8200

# This server's own URL as embedded in HLS master playlists.
SONARIUM_SERVER_BASE_URL=http://192.168.1.10:18201

SONARIUM_HLS_CACHE_DIR=/var/cache/sonarium/hls
#SONARIUM_HLS_CACHE_MAX_MB=8192
#SONARIUM_HLS_MAX_TRANSCODES=2
#SONARIUM_LOG_LEVEL=info
